<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTheme" parent="Theme.Light" />

    <!-- Card base - used by dark theme -->
    <style name="Card">
        <item name="android:duplicateParentState">true</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">18dp</item>
        <item name="android:paddingBottom">18dp</item>
    </style>

    <!-- Card.Light - used by light theme (inherits Card) -->
    <style name="Card.Light" />

    <!-- Buttons: legendary purple tinted -->
    <style name="CardButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="iconPadding">10dp</item>
        <item name="backgroundTint">@color/leg_accent_soft</item>
        <item name="android:textColor">@color/leg_accent_glow</item>
        <item name="iconTint">@color/leg_accent_glow</item>
        <item name="strokeColor">@color/leg_card_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <!-- Title text - bright white -->
    <style name="CardTitle">
        <item name="android:textAppearance">?textAppearanceBodyLarge</item>
        <item name="android:textColor">@color/leg_text_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:lineSpacingExtra">1sp</item>
    </style>

    <!-- Summary text - muted -->
    <style name="CardSummary">
        <item name="android:textAppearance">?textAppearanceBodyMedium</item>
        <item name="android:textColor">@color/leg_text_muted</item>
        <item name="android:textSize">12sp</item>
        <item name="android:layout_marginTop">3dp</item>
    </style>

    <!-- Body content text -->
    <style name="CardContent">
        <item name="android:textAppearance">?textAppearanceBodyMedium</item>
        <item name="android:textColor">@color/leg_text_secondary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:lineSpacingMultiplier">1.45</item>
    </style>

    <!-- Icon container - legendary rounded square with border -->
    <style name="CardIcon">
        <item name="android:layout_width">42dp</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:background">@drawable/shape_legendary_icon_bg</item>
        <item name="android:tint">@color/leg_accent_glow</item>
        <item name="android:tintMode">src_in</item>
        <item name="android:padding">9dp</item>
        <item name="android:scaleType">fitCenter</item>
    </style>

    <style name="GrantPermissions" parent="@style/AppTheme">
        <item name="android:colorBackground">?colorBackgroundFloating</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Dialog</item>
    </style>

    <style name="TerminalTutorialText">
        <item name="android:textAppearance">?textAppearanceBodyMedium</item>
        <item name="android:minHeight">32dp</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="FilledCard" parent="@style/Widget.Material3.CardView.Filled">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">-4dp</item>
        <item name="android:layout_marginEnd">-4dp</item>
        <item name="android:checkable">true</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:clipChildren">false</item>
        <item name="android:clipToPadding">false</item>
        <item name="cardCornerRadius">22dp</item>
        <item name="contentPaddingStart">20dp</item>
        <item name="contentPaddingEnd">20dp</item>
        <item name="contentPaddingLeft">20dp</item>
        <item name="contentPaddingRight">20dp</item>
        <item name="contentPaddingTop">18dp</item>
        <item name="contentPaddingBottom">18dp</item>
        <item name="cardBackgroundColor">@color/leg_card</item>
    </style>

    <style name="GrantPermissionsButtons">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">24dp</item>
        <item name="android:layout_marginEnd">24dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:padding">16dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">?textColorOnPrimaryContainer</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="GrantPermissionsButtons.Top">
        <item name="android:background">@drawable/grant_permissions_buttons_top</item>
        <item name="android:layout_marginBottom">2dp</item>
    </style>

    <style name="GrantPermissionsButtons.Buttom">
        <item name="android:background">@drawable/grant_permissions_buttons_bottom</item>
        <item name="android:layout_marginTop">2dp</item>
    </style>


    <style name="CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

</resources>

    <!-- SimpleMenuPreference stubs - actual implementation in rikka library -->
    <style name="Preference.SimpleMenuPreference" parent="@style/Preference" />
    <style name="Widget.Preference.SimpleMenuPreference.PopupMenu" parent="@android:style/Widget.PopupMenu" />
    <style name="ThemeOverlay.Preference.SimpleMenuPreference.PopupMenu" parent="" />

