<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/leg_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="94dp"
        android:paddingBottom="76dp"
        android:clipToPadding="false"
        android:fitsSystemWindows="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <!-- ══════════ HERO HEADER CARD (always fully visible) ══════════ -->
            <com.google.android.material.card.MaterialCardView
                style="?attr/materialCardViewFilledStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/leg_card"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/leg_accent_border"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <!-- Icon + Title row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <!-- Root status badge -->
                        <FrameLayout
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_root_badge"
                            android:layout_marginEnd="14dp">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_magisk_root"
                                android:tint="@color/leg_accent" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/magisk_root_title"
                                    android:textColor="@color/leg_text"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.01" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="6dp"
                                    android:text="⭐"
                                    android:textSize="16sp" />

                            </LinearLayout>

                            <TextView
                                android:id="@+id/tv_root_status_badge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="● Checking root…"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/leg_text_secondary" />

                        </LinearLayout>

                        <!-- Telegram icon button -->
                        <ImageView
                            android:id="@+id/btn_telegram"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_icon_btn"
                            android:padding="10dp"
                            android:src="@drawable/ic_open_in_new"
                            android:tint="@color/leg_cyan"
                            android:clickable="true"
                            android:focusable="true"
                            android:contentDescription="Telegram" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/magisk_root_subtitle"
                        android:textColor="@color/leg_text_secondary"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.3" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════ DIRECT INSTALL CARD ══════════ -->
            <com.google.android.material.card.MaterialCardView
                style="?attr/materialCardViewFilledStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="@color/leg_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/leg_accent_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- Card header row with icon -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="20dp"
                            android:background="@color/leg_accent"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/magisk_direct_install_title"
                            android:textColor="@color/leg_text"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:text="@string/magisk_direct_install_desc"
                        android:textColor="@color/leg_text_secondary"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.3" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_root_install"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:backgroundTint="@color/leg_accent"
                        android:text="@string/magisk_btn_install"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:cornerRadius="14dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════ PATCH BOOT IMAGE CARD ══════════ -->
            <com.google.android.material.card.MaterialCardView
                style="?attr/materialCardViewFilledStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="@color/leg_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/leg_card_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="20dp"
                            android:background="@color/leg_accent_secondary"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/magisk_patch_boot_title"
                            android:textColor="@color/leg_text"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:text="@string/magisk_patch_boot_desc"
                        android:textColor="@color/leg_text_secondary"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.3" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_patch_boot"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:backgroundTint="@color/leg_accent_secondary"
                        android:text="@string/magisk_btn_patch"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:cornerRadius="14dp" />

                    <TextView
                        android:id="@+id/tv_patched_path"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@color/leg_green_soft"
                        android:padding="10dp"
                        android:textColor="@color/leg_green"
                        android:textSize="12sp"
                        android:visibility="gone"
                        app:cornerRadius="10dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════ FLASH MODULE CARD ══════════ -->
            <com.google.android.material.card.MaterialCardView
                style="?attr/materialCardViewFilledStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="@color/leg_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/leg_card_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="20dp"
                            android:background="@color/leg_orange"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/magisk_flash_module_title"
                            android:textColor="@color/leg_text"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:text="@string/magisk_flash_module_desc"
                        android:textColor="@color/leg_text_secondary"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.3" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_flash_module"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:backgroundTint="@color/leg_orange"
                        android:text="@string/magisk_btn_flash"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:cornerRadius="14dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════ ROOT ADD-ONS CARD (Magisk Modules style) ══════════ -->
            <com.google.android.material.card.MaterialCardView
                style="?attr/materialCardViewFilledStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="@color/leg_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/leg_card_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="20dp"
                            android:background="@color/leg_cyan"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/root_addons_title"
                            android:textColor="@color/leg_text"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:text="@string/root_addons_desc"
                        android:textColor="@color/leg_text_secondary"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_root_addons"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="@string/root_addons_open"
                        android:textColor="@color/leg_cyan"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:strokeColor="@color/leg_cyan"
                        app:cornerRadius="14dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════ UNROOT CARD (Danger Zone) ══════════ -->
            <com.google.android.material.card.MaterialCardView
                style="?attr/materialCardViewFilledStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="#1A0D0D"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#FF1744"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="20dp"
                            android:background="#FF1744"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/unroot_title"
                            android:textColor="#FF6B6B"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:text="@string/unroot_desc"
                        android:textColor="#CC8888"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.3" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_unroot"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:backgroundTint="#FF1744"
                        android:text="@string/unroot_btn"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:cornerRadius="14dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Progress Bar -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progress_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:indeterminate="true"
                android:visibility="gone"
                app:trackColor="@color/leg_card"
                app:indicatorColor="@color/leg_accent" />

            <!-- ══════════ LOGS CARD ══════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/console_card"
                style="?attr/materialCardViewFilledStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:visibility="gone"
                app:cardBackgroundColor="#0A0A14"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/leg_accent_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Logs title bar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:background="#12122A">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Logs"
                            android:textColor="@color/leg_accent"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="root@android"
                            android:textColor="#5050A0"
                            android:textSize="10sp" />

                    </LinearLayout>

                    <ScrollView
                        android:id="@+id/scroll_console"
                        android:layout_width="match_parent"
                        android:layout_height="220dp">

                        <TextView
                            android:id="@+id/tv_console"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:padding="16dp"
                            android:textColor="#C8B4F8"
                            android:textSize="12sp"
                            android:lineSpacingMultiplier="1.6" />

                    </ScrollView>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Nav hidden - navigation handled by HomeActivity -->
    <LinearLayout
        android:id="@+id/bottom_nav_bar"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:layout_gravity="bottom"
        android:visibility="gone" >

        <TextView android:id="@+id/nav_btn_home"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:visibility="gone" />

        <TextView android:id="@+id/nav_btn_settings"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:visibility="gone" />

    </LinearLayout>

</FrameLayout>
