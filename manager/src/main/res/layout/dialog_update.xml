<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/update_dialog_bg"
    android:paddingBottom="8dp">

    <!-- Accent top bar -->
    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="@color/leg_accent_border" />

    <!-- Header: icon + title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_launcher"
            android:scaleType="fitCenter" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/update_dialog_title"
                android:textColor="@color/leg_text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/update_version_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/leg_accent_glow"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- NEW badge -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NEW"
            android:textColor="@color/leg_bg"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:background="@drawable/update_new_badge"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/leg_divider"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp" />

    <!-- Release notes -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:maxHeight="180dp">

        <TextView
            android:id="@+id/update_release_notes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/leg_text_secondary"
            android:textSize="13sp"
            android:lineSpacingExtra="3dp" />

    </ScrollView>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:paddingTop="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_update_later"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/update_dialog_later"
            android:textColor="@color/leg_text_secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_update_now"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/update_dialog_install"
            android:backgroundTint="@color/leg_accent"
            android:textColor="@color/leg_text_primary" />

    </LinearLayout>

</LinearLayout>
