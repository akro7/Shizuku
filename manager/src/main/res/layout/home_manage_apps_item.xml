<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    style="?homeCardStyle"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:paddingStart="8dp"
    android:paddingEnd="8dp">

    <ImageView
        android:id="@android:id/icon"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:background="@drawable/shape_icon_bg_accent"
        android:importantForAccessibility="no"
        android:padding="6dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_settings_outline_24dp"
        android:tint="@color/leg_accent_glow" />

    <TextView
        android:id="@android:id/text1"
        style="@style/CardTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:textSize="10sp"
        android:text="@string/home_app_management_view_authorized_apps" />

    <TextView
        android:id="@android:id/text2"
        style="@style/CardSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="center"
        android:textSize="9sp"
        android:text="@string/home_app_management_view_authorized_apps" />

</LinearLayout>
