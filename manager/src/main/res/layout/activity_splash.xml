<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/leg_bg">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="80dp">

        <!-- App icon – no background, no clipToOutline to avoid black corners -->
        <ImageView
            android:id="@+id/splash_icon"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@mipmap/ic_shizuku_hero"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true" />

        <!-- App name -->
        <TextView
            android:id="@+id/splash_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="SHIZUKU"
            android:textColor="@color/leg_text_primary"
            android:textSize="34sp"
            android:textStyle="bold"
            android:letterSpacing="0.12" />

        <!-- Tagline -->
        <TextView
            android:id="@+id/splash_tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="PRIVILEGED API · ANDROID"
            android:textColor="@color/leg_text_secondary"
            android:textSize="10sp"
            android:letterSpacing="0.20" />

        <!-- Loader dots -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:orientation="horizontal"
            android:gravity="center">

            <View
                android:id="@+id/dot1"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/splash_dot" />

            <View
                android:id="@+id/dot2"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/splash_dot" />

            <View
                android:id="@+id/dot3"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="@drawable/splash_dot" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
