<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/leg_bg"
    android:fillViewport="true"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- Top glow accent line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/leg_accent_border" />

        <!-- Hero section with anime character photo -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@drawable/dev_hero_bg"
            android:clipToPadding="false">

            <!-- Glow circle — perfectly centered -->
            <View
                android:layout_width="148dp"
                android:layout_height="148dp"
                android:layout_gravity="center"
                android:background="@drawable/dev_glow_circle" />

            <!-- Avatar — circle clipped, fully visible -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/dev_logo"
                android:layout_width="130dp"
                android:layout_height="130dp"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:src="@drawable/dev_avatar"
                app:shapeAppearanceOverlay="@style/CircleImageView"
                app:strokeColor="@color/leg_accent_glow"
                app:strokeWidth="2dp" />

        </FrameLayout>

        <!-- Name + badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="18dp"
            android:paddingBottom="4dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ahmed Younis"
                android:textColor="@color/leg_text_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                android:letterSpacing="0.03" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text=" AKRO "
                android:textColor="@color/leg_accent_glow"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.18"
                android:background="@drawable/dev_badge_bg"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Android Developer · Modder · Builder"
                android:textColor="@color/leg_text_secondary"
                android:textSize="11sp"
                android:gravity="center" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/leg_divider"
            android:layout_marginTop="18dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp" />

        <!-- Info cards — row 1: Telegram + Contact side by side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:weightSum="2">

            <!-- Telegram handle card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:background="@drawable/dev_info_card_bg"
                android:padding="14dp"
                android:layout_marginEnd="6dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@drawable/ic_baseline_link_24"
                    android:tint="@color/leg_cyan"
                    android:background="@drawable/dev_icon_bg_cyan"
                    android:padding="8dp"
                    android:scaleType="fitCenter" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Telegram"
                        android:textColor="@color/leg_text_secondary"
                        android:textSize="9sp"
                        android:letterSpacing="0.06" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@A_KOJO"
                        android:textColor="@color/leg_cyan"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Contact card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:background="@drawable/dev_info_card_bg"
                android:padding="14dp"
                android:layout_marginStart="6dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@drawable/ic_outline_notifications_active_24"
                    android:tint="@color/leg_accent_glow"
                    android:background="@drawable/dev_icon_bg_accent"
                    android:padding="8dp"
                    android:scaleType="fitCenter" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Contact"
                        android:textColor="@color/leg_text_secondary"
                        android:textSize="9sp"
                        android:letterSpacing="0.06" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="01508294415"
                        android:textColor="@color/leg_text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Brand card — full width -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/dev_info_card_bg"
            android:padding="14dp"
            android:layout_marginTop="10dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_root_24dp"
                android:tint="@color/leg_magenta"
                android:background="@drawable/dev_icon_bg_magenta"
                android:padding="8dp"
                android:scaleType="fitCenter" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Developer Brand"
                    android:textColor="@color/leg_text_secondary"
                    android:textSize="10sp"
                    android:letterSpacing="0.06" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shizuku ⭐"
                    android:textColor="@color/leg_magenta"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Footer quote -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginStart="28dp"
            android:layout_marginEnd="28dp"
            android:text="&quot;Built with precision, shaped by passion.&quot;"
            android:textColor="@color/leg_text_muted"
            android:textSize="12sp"
            android:gravity="center"
            android:fontFamily="serif"
            android:textStyle="italic" />

    </LinearLayout>

</ScrollView>
