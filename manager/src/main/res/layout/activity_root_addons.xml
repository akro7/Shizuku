<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/leg_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ══ TOP BAR ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@color/leg_card"
            android:elevation="4dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_close_24"
                android:tint="@color/leg_text_secondary"
                android:padding="6dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Modules"
                android:textColor="@color/leg_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Refresh -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_refresh"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:icon="@drawable/ic_refresh_24"
                app:iconTint="@color/leg_text_secondary" />

        </LinearLayout>

        <!-- ══ MODULE LIST ══ -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_addons"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone"
            android:clipToPadding="false"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="80dp" />

        <!-- ══ EMPTY STATE ══ -->
        <LinearLayout
            android:id="@+id/tv_empty_addons"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="40dp"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📦"
                android:textSize="52sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No modules installed"
                android:textColor="@color/leg_text"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/root_addons_empty"
                android:textColor="@color/leg_text_secondary"
                android:textSize="13sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4" />

        </LinearLayout>

    </LinearLayout>

    <!-- ══ PROGRESS BAR ══ -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progress_bar_addons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:indeterminate="true"
        android:visibility="gone"
        app:indicatorColor="@color/leg_accent"
        app:trackColor="@color/leg_card" />

    <!-- ══ LOGS CARD (bottom sheet style) ══ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/console_card_addons"
        style="?attr/materialCardViewFilledStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="76dp"
        android:visibility="gone"
        app:cardBackgroundColor="#0A0A14"
        app:cardCornerRadius="18dp"
        app:cardElevation="8dp"
        app:strokeColor="@color/leg_accent_border"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="#12122A">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Logs"
                    android:textColor="@color/leg_accent"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="modules"
                    android:textColor="#5050A0"
                    android:textSize="10sp" />

            </LinearLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="160dp">

                <TextView
                    android:id="@+id/tv_console_addons"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:padding="14dp"
                    android:textColor="#C8B4F8"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.5" />

            </ScrollView>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ══ FAB: Install Module ══ -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btn_install_addon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="84dp"
        android:text="Install Module"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        app:backgroundTint="@color/leg_accent"
        app:icon="@drawable/ic_adb_24dp"
        app:iconTint="@android:color/white" />

    <!-- ══ Bottom Nav ══ -->
    <LinearLayout
        android:id="@+id/bottom_nav_bar"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="12dp"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/nav_btn_home"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_nav_inactive"
            android:drawablePadding="6dp"
            android:drawableStart="@drawable/ic_home_24"
            android:drawableTint="@color/leg_text_secondary"
            android:gravity="center"
            android:text="@string/main_navigation_home"
            android:textColor="@color/leg_text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</FrameLayout>
