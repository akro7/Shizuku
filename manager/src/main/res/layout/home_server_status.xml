<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    style="?homeCardStyle"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="24dp"
    android:paddingBottom="20dp"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:gravity="center_horizontal">

    <!-- Mascot with Shizuku V14 glow + hexagon layers -->
    <FrameLayout
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:layout_marginBottom="16dp">

        <!-- Outer glow ring -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/shape_mascot_glow_outer"
            android:layout_gravity="center"/>

        <!-- Hexagon BG -->
        <View
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_gravity="center"
            android:background="@drawable/shape_mascot_hex_bg"
            android:rotation="10"/>

        <!-- Inner circle white glow -->
        <View
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="center"
            android:background="@drawable/shape_mascot_circle"/>

        <!-- Mascot icon -->
        <ImageView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_mascot_hero"
            android:importantForAccessibility="no"
            android:scaleType="fitCenter"/>

    </FrameLayout>

    <!-- Status title + indicator icon -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@android:id/text1"
            style="@style/CardTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/leg_text_primary"
            android:duplicateParentState="true"
            tools:text="Shizuku is running" />

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_server_ok_24dp"
            android:tint="@color/leg_accent"
            android:importantForAccessibility="no"/>

    </LinearLayout>

    <!-- Version / status subtitle -->
    <TextView
        android:id="@android:id/text2"
        style="@style/CardSummary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/leg_accent_glow"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="4dp"
        android:duplicateParentState="true"
        tools:text="Version 13.6, root" />

</LinearLayout>
